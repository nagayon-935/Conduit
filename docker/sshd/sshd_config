Port 22
PermitRootLogin no

# パスワード認証を無効化（証明書認証のみ許可）
PasswordAuthentication no
ChallengeResponseAuthentication no
UsePAM no

# Vault CA が署名した証明書を信頼する
TrustedUserCAKeys /etc/ssh/trusted-ca.pub

# ログ
LogLevel INFO
PrintMotd no

# Keep-alive / 死活監視
# 60秒ごとにkeepaliveを送信し、10回無応答（= 約10分）で強制切断
ClientAliveInterval 60
ClientAliveCountMax 10
