# Conduit 本番環境変数テンプレート
# このファイルを .env.prod にコピーして実際の値を設定してください
# cp .env.prod.example .env.prod

# Vault サーバーのアドレス
VAULT_ADDR=http://192.168.x.x:8200

# Vault アクセストークン（scripts/vault-init-prod.sh で生成した Conduit 専用トークン）
VAULT_TOKEN=hvs.xxxxxxxxxxxxxxxxxxxxxxxx

# Vault SSH Secrets Engine の設定（変更不要）
VAULT_SSH_ROLE=conduit
VAULT_SSH_MOUNT=ssh

# Conduit バックエンドのリッスンアドレス（変更不要）
SERVER_ADDR=:8080

# セッション設定（必要に応じて調整）
GRACE_PERIOD=15m
SESSION_GC_INTERVAL=1m
